PORT=3000
DATABASE_URL=postgresql://riskedu:riskedu@postgres:5432/riskedu
ML_SERVICE_URL=http://ml-service:8000
JWT_SECRET=change_me_to_long_random_string
JWT_EXPIRES_IN=1d
CORS_ORIGIN=http://localhost:5173

# SMTP settings
SMTP_FROM=no-reply@example.com
SMTP_HOST=smtp.sendgrid.net
SMTP_PASS=
SMTP_PORT=587
SMTP_USER=apikey

# Optional Email API providers (preferable for cloud deploys)
# SendGrid API (recommended on Render):
SENDGRID_API_KEY=
SENDGRID_FROM=no-reply@example.com
# Resend API (optional fallback):
RESEND_API_KEY=
RESEND_FROM=no-reply@example.com

# Optional AI key for suggestions/syllabus parsing fallback
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_SYLLABUS_MODEL=gemini-2.0-flash
